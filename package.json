{
  "name": "@fairezlc/autoreadme",
  "version": "0.1.0",
  "description": "CLI that detects your project and generates a professional README.md",
  "type": "module",
  "bin": {
    "autoreadme": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "pretest": "npm run build",
    "test": "node --test tests/detect.test.js tests/generate.test.js tests/init.test.js",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist"
  ],
  "keywords": ["readme", "documentation", "cli", "generator", "autoreadme"],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/FaiCP/AutoDOC.git"
  },
  "dependencies": {
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
